package main

import (
	"bytes"
	"encoding/json"
	"fmt"
	"net/http"
	"strings"
)

func main() {
	reqBody := map[string]interface{}{
		"model":  "llama3.1",
		"prompt": "Say 'Hello world'",
		"stream": false,
	}

	reqJSON, _ := json.Marshal(reqBody)

	resp, err := http.Post("http://localhost:11434/api/generate",
		"application/json", bytes.NewBuffer(reqJSON))
	if err != nil {
		fmt.Printf("Error connecting to Ollama: %v\n", err)
		fmt.Println("Make sure Ollama is running: ollama serve")
		return
	}
	defer resp.Body.Close()

	var result map[string]interface{}
	json.NewDecoder(resp.Body).Decode(&result)

	if response, ok := result["response"].(string); ok {
		fmt.Printf("Ollama response: %s\n", strings.TrimSpace(response))
	} else {
		fmt.Println("No response from Ollama")
	}
}




